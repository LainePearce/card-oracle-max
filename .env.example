# Copy to .env — never commit .env to version control.

# ── Qdrant ────────────────────────────────────────────────────────
QDRANT_HOST=localhost                    # change to EC2 IP for remote test instance
QDRANT_PORT=6334                         # gRPC port
QDRANT_API_KEY=your-secret-key
QDRANT_USE_GRPC=true
QDRANT_COLLECTION=cards
QDRANT_SINGLE_NODE=true                  # set false for multi-node cluster

# ── OpenSearch — Extant cluster (read-only) ───────────────────────
OPENSEARCH_HOST=search-es130point-vector-h3eaau7mwcpyhgynkthfcwzeje.aos.us-west-1.on.aws
OPENSEARCH_PORT=443
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=true

# Auth — choose ONE:
# Option A: Basic auth
OPENSEARCH_USE_IAM=false
OPENSEARCH_USER=your-username
OPENSEARCH_PASSWORD=your-password

# Option B: IAM auth (uncomment and set OPENSEARCH_USE_IAM=true)
# OPENSEARCH_USE_IAM=true

# ── New self-managed OpenSearch cluster (document store, no KNN) ──
# Populated from RDS via dual_write_pipeline.py during backfill.
# Used by new_os_writer.py — separate from the extant read-only cluster above.
OPENSEARCH_DOCS_HOST=card-oracle-os-nlb-XXXX.elb.us-west-1.amazonaws.com
OPENSEARCH_DOCS_PORT=9200
OPENSEARCH_DOCS_USE_SSL=false
OPENSEARCH_DOCS_USER=admin
OPENSEARCH_DOCS_PASSWORD=your-strong-password-here

# ── RDS MySQL — Primary (backfill source, current DB) ─────────────
RDS_HOST=your-rds-instance.us-west-1.rds.amazonaws.com
RDS_PORT=3306
RDS_USER=your-rds-user
RDS_PASSWORD=your-rds-password
RDS_DATABASE=your-database-name

# ── RDS MySQL — Secondary (older DB, pre-cutover) ─────────────────
# The dual_write_pipeline queries BOTH databases for each date partition.
# Records from the primary win on ID collision; secondary fills any gaps.
# Leave RDS2_HOST empty to disable secondary (primary-only mode).
RDS2_HOST=your-old-rds-instance.us-west-1.rds.amazonaws.com
RDS2_PORT=3306
RDS2_USER=your-rds2-user
RDS2_PASSWORD=your-rds2-password
RDS2_DATABASE=your-old-database-name

# ── Development stage ─────────────────────────────────────────────
DEVELOPMENT_STAGE=1

# ── AWS ───────────────────────────────────────────────────────────
AWS_REGION=us-west-1

# ── S3 Vector Store ───────────────────────────────────────────────
S3_VECTOR_BUCKET=your-vector-store-bucket
S3_VECTOR_PREFIX=vectors
S3_CHECKPOINT_PREFIX=checkpoints

# ── Embedding models ──────────────────────────────────────────────
# Qdrant vectors (Stage 1 backfill): ViT-L/14 openai → 768-dim
CLIP_MODEL=ViT-L/14
# OpenSearch control system (experiment only): ViT-B-32 openai → 512-dim
# Matches Xenova/clip-vit-base-patch32 used to build the extant OS imageVector field.
CLIP_MODEL_OS=ViT-B-32
MINILM_MODEL=sentence-transformers/all-MiniLM-L6-v2
PROJECTION_MODEL_PATH=models/image_to_specifics_projection.pt
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE_IMAGE=256
EMBEDDING_BATCH_SIZE_TEXT=1024

# ── Search UI (tools/search_ui_server.py) ────────────────────────
# Pre-built auth header for OpenSearch (base64 of "user:password")
OPENSEARCH_AUTH_HEADER=Basic ZXMxMzBwb2ludC12ZWN0b3ItbWFzdGVyOjlCVFVzTEt1KklWenQzR0Y=
# Index pattern the UI searches across
OPENSEARCH_INDEX=*,-*.*,-*-live*
# Local port for the UI server
UI_PORT=8080
# Optional: GPU worker URL for fast CLIP encoding (leave empty to use local CPU)
# GPU_WORKER_URL=http://<ec2-public-ip>:8081
GPU_WORKER_URL=
# GPU worker API server settings (set these on the EC2 worker instance)
GPU_API_PORT=8081
GPU_API_HOST=0.0.0.0

# ── Experiment ────────────────────────────────────────────────────
EXPERIMENT_ID=EXP-VSC-2026-001
EXPERIMENT_RESULTS_DIR=experiment/results
EXPERIMENT_QUERY_SET_PATH=experiment/dataset/query_set.parquet
EXPERIMENT_GROUND_TRUTH_PATH=experiment/dataset/ground_truth.parquet
EXPERIMENT_CONCURRENT_THREADS=50
EXPERIMENT_WARMUP_QUERIES=1000
EXPERIMENT_REPETITIONS=5
